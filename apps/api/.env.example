# API .env — copy to apps/api/.env and fill in your values.
# This file is NOT used by docker-compose directly; it's loaded by the container
# via env_file: apps/api/.env in docker-compose.yml.

# ── Server ────────────────────────────────────────────────────────────────────
# PORT and FRONTEND_ORIGIN are set by docker-compose; you don't need them here
# for production. Keep them for local dev:
FRONTEND_ORIGIN=http://localhost:3001
PORT=3002

# ── SparkCo messaging (email + WhatsApp) ─────────────────────────────────────
SPARKCO_API_URL=https://api.sparkco.vip/api/v1
SPARKCO_API_KEY=your-sparkco-api-key

# ── Hardware device auth ──────────────────────────────────────────────────────
# Must be a long random secret. Generate with: openssl rand -hex 32
# Device callback URL: https://<DOMAIN>/api/access/bas-ip?branchId=<id>&token=<DEVICE_TOKEN>
DEVICE_TOKEN=a246b4d0aba5ac5cb4378aeb326cfbdd01545e587146a21a51ba53b9320da0d9

# ── BAS-IP AV-03BD (local network sync) ──────────────────────────────────────
# The panel lives on the gym's LAN — set this on a machine that can reach it.
# On the VPS (production), leave these unset; the Remote Access Server will
# handle all real-time access control and local-list sync will simply be skipped.
# Example: BASIP_DEVICE_URL=http://192.168.1.178
BASIP_DEVICE_URL=http://213.8.132.134:8081
BASIP_DEVICE_USERNAME=admin
BASIP_DEVICE_PASSWORD=123456
